{
  "name": "@trackyourapi/sdk",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript SDK for TrackYourAPI — AI API usage tracking",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["ai", "llm", "observability", "openai", "anthropic", "gemini", "tracking"],
  "author": "TrackYourAPI",
  "license": "MIT",
  "peerDependencies": {
    "openai": ">=4.0.0",
    "@anthropic-ai/sdk": ">=0.20.0",
    "@google/generative-ai": ">=0.1.0"
  },
  "peerDependenciesOptional": {
    "openai": true,
    "@anthropic-ai/sdk": true,
    "@google/generative-ai": true
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "openai": "^4.0.0",
    "@anthropic-ai/sdk": "^0.20.0",
    "@google/generative-ai": "^0.1.0"
  }
}
